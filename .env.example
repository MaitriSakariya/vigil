# ---- VIGIL environment (copy to .env) ----

# App
VIGIL_ENV=development
VIGIL_API_HOST=0.0.0.0
VIGIL_API_PORT=8000
VIGIL_LOG_LEVEL=info

# AI core (freellmapi) -- single OpenAI-compatible endpoint
VIGIL_LLM_BASE_URL=http://freellmapi:8080/v1
VIGIL_LLM_TOKEN=freellmapi-REPLACE_ME
VIGIL_LLM_CHAT_MODEL=auto
VIGIL_LLM_EMBED_MODEL=text-embedding-3-small

# Database (Postgres)
VIGIL_DB_URL=postgresql+psycopg://vigil:vigil@postgres:5432/vigil

# Vision
VIGIL_YOLO_WEIGHTS=vision/models/yolov8n.pt
VIGIL_FIRE_SMOKE_WEIGHTS=vision/models/fire_smoke.pt
VIGIL_CONF_THRESHOLD=0.35

# Queue / backpressure
VIGIL_FRAME_QUEUE_MAXSIZE=100
VIGIL_DROP_POLICY=drop_oldest

# Observability
VIGIL_METRICS_PORT=9000
